SUPABASE_PROJECT_ID="your-project-id"
SUPABASE_PUBLISHABLE_KEY="your-publishable-key"
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-publishable-key"
VITE_SUPABASE_URL="https://your-project.supabase.co"

# Required server-only secrets. Leave empty in this file and generate unique production values.
# SITE_SESSION_SECRET and LOG_CLEANUP_SECRET must contain at least 32 random characters.
SITE_SESSION_SECRET=""
SITE_SESSION_TTL_SECONDS="3600"
SITE_MASTER_PASSWORD=""
LOG_CLEANUP_SECRET=""

# Optional server-only Gemini provider. Store the API key in the deployment secret store.
# AI_PROVIDER may be "gemini" or "anthropic"; leave empty for automatic detection.
AI_PROVIDER=""
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-3.5-flash"

# Optional scraper queue deadline in milliseconds (1000-60000).
SCRAPER_QUEUE_TIMEOUT_MS="10000"

# Optional comma-separated hostname rules. A leading dot allows subdomains.
REPORT_IMAGE_ALLOWED_HOSTS=".copart.com,.iaai.com"
REPORT_IMAGE_MAX_BYTES="2097152"
REPORT_IMAGE_TOTAL_BYTES="12582912"
