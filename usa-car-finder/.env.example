AI_ANALYSIS_MODE=auto
AI_ANALYSIS_STRICT=false
PYDANTIC_DISABLE_PLUGINS=__all__
REPORT_DOWNLOAD_IMAGES=false
REPORT_IMAGE_TIMEOUT_SECONDS=3
MAX_RESULTS_PER_SOURCE=30
SEARCH_MAX_PAGES=5
SEARCH_DETAIL_MULTIPLIER=4
STRICT_SCAN_MAX_RESULTS_THRESHOLD=3
HEADLESS=true
SLOW_MO_MS=1500
