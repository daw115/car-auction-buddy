ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_TIMEOUT_SECONDS=120
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.2
OPENAI_MAX_OUTPUT_TOKENS=12000
OPENAI_TIMEOUT_SECONDS=120
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_OUTPUT_TOKENS=8192
GEMINI_TIMEOUT_SECONDS=120
GEMINI_TEMPERATURE=0.4
AI_ANALYSIS_MODE=auto
AI_ANALYSIS_STRICT=false
PYDANTIC_DISABLE_PLUGINS=__all__
REPORT_DOWNLOAD_IMAGES=false
REPORT_IMAGE_TIMEOUT_SECONDS=3
MAX_RESULTS_PER_SOURCE=30
SEARCH_MAX_PAGES=5
SEARCH_DETAIL_MULTIPLIER=2
# Early exit listing pagination: po N kolejnych pustych stronach przerwij
# (oszczędza ~30s/strona dla rzadkich modeli z 0/mało wyników).
SEARCH_EMPTY_STREAK_THRESHOLD=2
IAAI_PARALLEL_DETAIL=3
EXTENSION_IFRAME_WAIT_SECONDS=8
AUTOHELPERBOT_DIRECT_WAIT_SECONDS=8
STRICT_SCAN_MAX_RESULTS_THRESHOLD=3
HEADLESS=true
SLOW_MO_MS=1500
CHROME_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
LOGIN_NAV_TIMEOUT_MS=15000
DETAIL_NAV_TIMEOUT_MS=60000
EXTENSION_IFRAME_WAIT_SECONDS=15
AUTOHELPERBOT_DIRECT_WAIT_SECONDS=20
AUTOHELPERBOT_DIRECT_ENABLED=true
AUTOHELPERBOT_POST_LOGIN_WAIT_SECONDS=5
AUTOHELPERBOT_SECURITY_WAIT_SECONDS=20
BLOCK_MEDIA_ASSETS=false
HTML_CACHE_DIR=./data/html_cache
REPORTS_DIR=./data/reports
APP_DATABASE_PATH=./data/app.db
CHROME_PROFILE_DIR=./data/chromium_profile
BROWSER_CHANNEL=chromium
BROWSER_EXECUTABLE_PATH=
BROWSER_LAUNCH_TIMEOUT_MS=90000
USE_EXTENSIONS=false
KEEP_BROWSER_OPEN=true
DISABLED_EXTENSIONS=auctiongate
USE_MOCK_DATA=false
FILTER_SELLER_INSURANCE_ONLY=false
FORCE_REFRESH=true
CACHE_MAX_AGE_HOURS=24
MIN_AUCTION_WINDOW_HOURS=12
MAX_AUCTION_WINDOW_HOURS=168
ORCHESTRATOR_MAX_RESULTS=10
COPART_ACTIVE_LOGIN=true
COPART_POST_LOGIN_WAIT_SECONDS=10
COPART_SECURITY_WAIT_SECONDS=10
IAAI_ACTIVE_LOGIN=true
IAAI_POST_LOGIN_WAIT_SECONDS=10
AUTOHELPERBOT_EMAIL=
AUTOHELPERBOT_PASSWORD=

# === TELEGRAM BOT (multi-user broadcast notifications) ===
# Token od @BotFather (komenda /newbot)
TELEGRAM_BOT_TOKEN=
# Kod zaproszenia. Brokerzy wpisują "/start KOD" do bota.
# Gdy puste — każdy z linkiem do bota może się zarejestrować (open mode).
TELEGRAM_INVITE_CODE=
# (opcjonalnie) Inline button "🔗 Otwórz w UI" w wiadomości — link do dashboardu/UI.
TELEGRAM_UI_BASE_URL=
# (opcjonalnie) Long-poll timeout w sekundach (default 30).
TELEGRAM_POLL_TIMEOUT=30
TELEGRAM_HTTP_TIMEOUT=30

# === LLM provider dla parsera wiadomości + hybrid raportów ===
# 'anthropic' (default, stabilny) lub 'gemini' (free tier, 15 RPM / 1500 RPD).
# Anthropic primary = brak 429, Gemini idzie do fallback gdy Anthropic nie zadziała.
LLM_REPORTS_PROVIDER=anthropic
# Fallback (gdy primary fails). Anthropic→Gemini lub odwrotnie.
LLM_REPORTS_FALLBACK_ANTHROPIC=true

# === COPART filtrowanie server-side (drastycznie zmniejsza liczbę requestów) ===
# FETI Run and Drive (CERT-D) — default true. Wycina ~95% lotów które nie odpalają.
COPART_FILTER_RUN_AND_DRIVE=true
# DMG exclusion (Flood/Fire) — opt-in. Best effort, sprawdź `total=` w logach.
COPART_FILTER_EXCLUDE_DAMAGE=false

# === IAAI DOM filtrowanie (opt-in: klika filtry UI przed scrapingiem) ===
IAAI_USE_DOM_FILTERS=false

# === Frame damage vision check (Claude vision dla lotów z FRONT/REAR damage) ===
# Per lot z damage_primary zawierającym FRONT/REAR → Claude analizuje zdjęcia
# i sprawdza czy uszkodzona jest belka konstrukcyjna (auto-ODRZUĆ gdy tak).
# Cache 60 dni per VIN w data/frame_damage_cache.json.
# Koszt: ~$0.02 per lot (4 obrazy × 1.5k tokens vision input).
FRAME_DAMAGE_VISION_ENABLED=true
FRAME_DAMAGE_CACHE_PATH=data/frame_damage_cache.json
FRAME_DAMAGE_CACHE_TTL_DAYS=60
FRAME_DAMAGE_MAX_IMAGES=4

# === Bidfax (historyczne ceny sprzedaży) — default OFF ===
# Wymaga: AuctionGate extension (full_vin loty) + ręczny CF warmup co 1-7 dni
# + osobny Chrome na CDP porcie. Patrz bidfax_chrome_debug.sh.
BIDFAX_ENRICHMENT_ENABLED=false
# Gdy włączysz: np. http://localhost:9222 (lub http://<windows_ip>:9222 z WSL2)
BIDFAX_CHROME_CDP_URL=
BIDFAX_HEADLESS=false
BIDFAX_DEBUG_SCREENSHOTS=false
BIDFAX_CACHE_PATH=data/bidfax_cache.json
BIDFAX_CACHE_TTL_DAYS=60
BIDFAX_LOG_DIR=./logs
BIDFAX_CHROME_PROFILE_DIR=data/chrome_profile_bidfax
