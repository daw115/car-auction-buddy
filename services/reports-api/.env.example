# Supabase credentials (the service-role key bypasses RLS; keep it server-only)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""

# Required, unique API key with at least 32 random characters
REPORTS_API_KEY=""

# Optional comma-separated exact browser origins; wildcard origins are rejected
REPORTS_API_CORS_ORIGINS=""
